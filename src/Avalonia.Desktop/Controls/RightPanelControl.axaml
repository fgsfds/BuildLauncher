<UserControl x:Class="Avalonia.Desktop.Controls.RightPanelControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia.Tight"
             xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:RightPanelViewModel"
             mc:Ignorable="d">

    <Grid RowDefinitions="*,auto,auto,auto,auto,auto">

        <ScrollViewer Grid.Row="0">

            <StackPanel Orientation="Vertical">

                <Image Height="200"
                       IsVisible="{Binding IsPreviewVisible}"
                       Source="{Binding SelectedAddonPreview}" />

                <md:MarkdownScrollViewer Name="Description"
                                         Margin="10,5"
                                         Markdown="{Binding SelectedAddonDescription}">

                    <md:MarkdownScrollViewer.Styles>
                        <StyleInclude Source="/Styles/MarkdownStyle.axaml" />
                    </md:MarkdownScrollViewer.Styles>

                </md:MarkdownScrollViewer>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              Margin="5"
              ColumnDefinitions="auto,*"
              IsVisible="{Binding HasOptions}"
              RowDefinitions="auto,auto,auto">

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Margin="5,10,5,5"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemAccentColor}"
                       Text="Addon options" />

            <ItemsControl Grid.Row="1"
                          Margin="5"
                          ItemsSource="{Binding AddonOptions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="10,5"
                   HorizontalAlignment="Center"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SystemAccentColor}"
                   Text="{Binding SelectedAddonPlaytime}" />

        <StackPanel Grid.Row="3"
                    IsVisible="{Binding IsMetadataUpdateAvailable}"
                    Orientation="Horizontal">

            <TextBlock Margin="10,5"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemAccentColor}"
                       Text="Metadata update availble" />

            <Button Margin="10,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Gray"
                    Command="{Binding UpdateMetadataAsync}"
                    Content="Update" />

        </StackPanel>

    </Grid>

</UserControl>
