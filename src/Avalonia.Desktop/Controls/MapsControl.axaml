<ctrl:AddonListControlBase x:Class="Avalonia.Desktop.Controls.MapsControl"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:behaviors="clr-namespace:Avalonia.Desktop.Behaviors"
                          xmlns:ctrl="clr-namespace:Avalonia.Desktop.Controls"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:i="https://github.com/projektanker/icons.avalonia"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
                          d:DesignHeight="450"
                          d:DesignWidth="800"
                          x:DataType="vm:MapsViewModel"
                          mc:Ignorable="d">

    <Grid ColumnDefinitions="2*,*" RowDefinitions="auto,*,auto">

        <Grid Grid.Row="0"
              Grid.Column="0"
              Margin="0,0,0,5"
              ColumnDefinitions="auto,*,auto">

            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     PlaceholderText="Search"
                     Text="{Binding SearchBoxText}" />

            <Button Grid.Column="2"
                    Height="{Binding Bounds.Height, ElementName=SearchBox}"
                    Margin="5,0,0,0"
                    Command="{Binding ClearSearchBoxCommand}"
                    ToolTip.Tip="Clear search">
                <i:Icon Value="fa7-xmark" />
            </Button>

        </Grid>

        <ListBox x:Name="MapsList"
                 Grid.Row="1"
                 Grid.Column="0"
                 Padding="2"
                 ItemsSource="{Binding AddonsList}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 SelectedItem="{Binding SelectedAddon}"
                 SelectionChanged="OnMapsListSelectionChanged">

            <ListBox.ContextMenu>
                <ContextMenu Closed="ContextMenuClosed" Opened="ContextMenuOpened" />
            </ListBox.ContextMenu>

            <Interaction.Behaviors>
                <behaviors:ClearSelectionOnEmptySpaceBehavior />
                <behaviors:FileDropBehavior Command="{Binding ProcessDroppedFilesCommand}" />
            </Interaction.Behaviors>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>

                    <Grid ColumnDefinitions="auto,*">

                        <TextBlock Grid.Column="0"
                                   Margin="10"
                                   Padding="5"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Text="{Binding Title}"
                                   TextAlignment="Left"
                                   TextWrapping="NoWrap" />

                        <i:Icon Grid.Column="1"
                                Margin="5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                BorderBrush="Black"
                                BorderThickness="1"
                                FontSize="20"
                                Foreground="Crimson"
                                IsVisible="{Binding IsMetadataUpdateAvailable}"
                                ToolTip.Tip="Metadata update available"
                                Value="fa7-circle-exclamation" />

                    </Grid>

                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <ctrl:RightPanelControl x:Name="RightPanel"
                                Grid.Row="1"
                                Grid.Column="1" />

        <ctrl:PortsButtonsControl x:Name="BottomPanel"
                                  Grid.Row="2"
                                  Grid.Column="0" />

    </Grid>

</ctrl:AddonListControlBase>
