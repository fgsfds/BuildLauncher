<UserControl x:Class="Avalonia.Desktop.Controls.ModsControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Avalonia.Desktop.Behaviors"
             xmlns:ctrl="clr-namespace:Avalonia.Desktop.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:ModsViewModel"
             mc:Ignorable="d">

    <Grid ColumnDefinitions="2*,*" RowDefinitions="*,auto">

        <ListBox x:Name="ModsList"
                 Grid.Row="0"
                 Grid.Column="0"
                 Padding="2"
                 DragDrop.AllowDrop="True"
                 DragDrop.Drop="OnDrop"
                 ItemsSource="{Binding ModsList}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectedItem="{Binding SelectedAddon}"
                 SelectionChanged="OnModsListSelectionChanged">

            <Interaction.Behaviors>
                <behaviors:ClearSelectionOnEmptySpaceBehavior />
            </Interaction.Behaviors>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">

                        <StackPanel Orientation="Horizontal">

                            <CheckBox Margin="5,0,0,0"
                                      Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=((vm:ModsViewModel)DataContext).ModCheckboxPressedCommand}"
                                      CommandParameter="{Binding $parent[ListBoxItem].Content}"
                                      IsChecked="{Binding IsEnabled, Mode=OneWay}" />

                            <TextBlock Margin="10"
                                       VerticalAlignment="Center"
                                       Text="{Binding Title}" />

                            <i:Icon Margin="5"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    FontSize="20"
                                    Foreground="Crimson"
                                    IsVisible="{Binding IsMetadataUpdateAvailable}"
                                    ToolTip.Tip="Metadata update available"
                                    Value="fa7-circle-exclamation" />

                        </StackPanel>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ctrl:RightPanelControl x:Name="RightPanel"
                                Grid.Row="0"
                                Grid.Column="1" />

        <ctrl:PortsButtonsControl x:Name="BottomPanel"
                                  Grid.Row="1"
                                  Grid.Column="0" />

    </Grid>

</UserControl>
