<UserControl x:Class="Avalonia.Desktop.Controls.PortControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:PortViewModel"
             mc:Ignorable="d">

    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

        <Image Width="64"
               HorizontalAlignment="Center"
               Source="{Binding IconId, Converter={StaticResource CachedHashToBitmapConverter}}" />

        <TextBlock HorizontalAlignment="Center"
                   FontWeight="Black"
                   Text="{Binding Name, FallbackValue=Name}" />

        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <TextBlock Text="Installed version: " />
            <TextBlock Text="{Binding Version, FallbackValue=None}" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <TextBlock Foreground="{DynamicResource SystemAccentColor}" Text="Latest version: " />
            <TextBlock Foreground="{DynamicResource SystemAccentColor}" Text="{Binding LatestVersion, FallbackValue=None}" />
        </StackPanel>

        <ProgressBar Margin="5,10,5,5"
                     HorizontalAlignment="Center"
                     IsIndeterminate="{Binding IsCheckingForUpdates}"
                     Value="{Binding ProgressBarValue}" />

        <Grid Name="ButtonsGrid"
              Margin="0,0,0,10"
              HorizontalAlignment="Stretch"
              ColumnDefinitions="2*,*,*">

            <Button Name="InstallButton"
                    Grid.Column="0"
                    Height="{Binding #OpenFolderButton.Bounds.Height}"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Classes.isUninstalled="{Binding !IsInstalled}"
                    Classes.isUpdate="{Binding IsUpdateAvailable}"
                    Command="{Binding InstallCommand}"
                    Content="{Binding InstallButtonText, FallbackValue=Install}"
                    IsEnabled="{Binding CanBeInstalled}">

                <Button.Styles>
                    <Style Selector="Button.isUpdate">
                        <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
                    </Style>
                    <Style Selector="Button.isUninstalled">
                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark2}" />
                    </Style>
                </Button.Styles>

            </Button>

            <Button x:Name="OpenFolderButton"
                    Grid.Column="1"
                    Margin="5"
                    Padding="6"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding OpenFolderCommand}"
                    IsEnabled="{Binding IsInstalled}"
                    ToolTip.Tip="Open port folder...">
                <i:Icon Value="fa7-folder-open" />
            </Button>

            <Button Grid.Column="2"
                    Height="{Binding #OpenFolderButton.Bounds.Height}"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Crimson"
                    Command="{Binding UninstallCommand}"
                    IsEnabled="{Binding IsInstalled}"
                    ToolTip.Tip="Uninstall">
                <i:Icon Value="fa7-trash" />
            </Button>

        </Grid>

    </StackPanel>

</UserControl>
