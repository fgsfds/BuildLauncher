<UserControl x:Class="Avalonia.Desktop.Pages.AboutPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:AboutViewModel"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="*">

        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">

            <!--  Version  -->
            <Border Margin="10"
                    Padding="10"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource ButtonBackground}"
                    CornerRadius="3">

                <Grid ColumnDefinitions="auto,*, auto, auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Image Width="48"
                               RenderOptions.BitmapInterpolationMode="None"
                               Source="/Assets/logo.png" />
                        <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                            <TextBlock Margin="10,0"
                                       VerticalAlignment="Center"
                                       FontSize="18">
                                BuildLauncher
                            </TextBlock>
                            <TextBlock Margin="10,0"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Text="{Binding CurrentVersion}" />
                        </StackPanel>
                    </StackPanel>

                    <ProgressBar Grid.Column="1"
                                 Margin="30,0"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding CurrentUpdateState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:UpdateState.InProgress}}" />

                    <Button Grid.Column="2"
                            Margin="10,0"
                            Padding="10"
                            HorizontalAlignment="Right"
                            Classes.IsInProgress="{Binding CurrentUpdateState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:UpdateState.InProgress}}"
                            Classes.IsUpToDate="{Binding CurrentUpdateState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:UpdateState.UpToDate}}"
                            Classes.IsUpdateAvailable="{Binding CurrentUpdateState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:UpdateState.UpdateAvailable}}"
                            Classes.IsUpdateFailed="{Binding CurrentUpdateState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:UpdateState.UpdateFailed}}"
                            Command="{Binding CheckOrInstallUpdateCommand}">

                        <Button.Styles>
                            <Style Selector="Button.IsInProgress">
                                <Setter Property="Content" Value="Checking..." />
                            </Style>
                            <Style Selector="Button.IsUpdateFailed">
                                <Setter Property="Content" Value="Error while getting updates" />
                            </Style>
                            <Style Selector="Button.IsUpToDate">
                                <Setter Property="Content" Value="Already up-to-date" />
                            </Style>
                            <Style Selector="Button.IsUpdateAvailable">
                                <Setter Property="Content" Value="Download and install" />
                            </Style>
                        </Button.Styles>

                    </Button>
                    <Button Grid.Column="3"
                            Margin="0,0,10,0"
                            Padding="10"
                            HorizontalAlignment="Right"
                            Click="ShowChangelogClick"
                            IsVisible="{Binding CurrentUpdateState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:UpdateState.UpdateAvailable}}">
                        Changelog...
                    </Button>
                </Grid>
            </Border>

            <!--  Patreon  -->
            <Button Margin="10"
                    Padding="10"
                    HorizontalAlignment="Stretch"
                    Click="PatreonClick">
                <StackPanel Orientation="Horizontal">

                    <i:Icon FontSize="48" Value="fa7-patreon" />

                    <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="18">
                            Patreon
                        </TextBlock>
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="14">
                            Support me on Patreon
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Button>

            <!--  Discord  -->
            <Button Margin="10"
                    Padding="10"
                    HorizontalAlignment="Stretch"
                    Click="DiscordClick">
                <StackPanel Orientation="Horizontal">

                    <i:Icon FontSize="48" Value="fa7-discord" />

                    <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="18">
                            Discord server
                        </TextBlock>
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="14">
                            Join discussion on Discord
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Button>

            <!--  Github  -->
            <Button Margin="10"
                    Padding="10"
                    HorizontalAlignment="Stretch"
                    Click="GitHubClick">
                <StackPanel Orientation="Horizontal">

                    <i:Icon FontSize="48" Value="fa7-github" />

                    <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="18">
                            GitHub repository
                        </TextBlock>
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="14">
                            BuildLauncher is free and open source
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Button>

            <!--  Issues  -->
            <Button Margin="10"
                    Padding="10"
                    HorizontalAlignment="Stretch"
                    Click="GitHubIssuesClick">

                <StackPanel Orientation="Horizontal">

                    <i:Icon FontSize="48" Value="fa7-bug" />

                    <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="18">
                            Report a problem
                        </TextBlock>
                        <TextBlock Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontSize="14">
                            Create issue on GitHub
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
