<UserControl x:Class="Avalonia.Desktop.Pages.DevPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Avalonia.Desktop.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia.Tight"
             xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
             d:DesignHeight="2000"
             d:DesignWidth="1000"
             x:DataType="vm:DevViewModel"
             mc:Ignorable="d">

    <UserControl.Resources>
        <helpers:GameStringToEnumConverter x:Key="GameStringToEnumConverter" />
        <helpers:OptionParamsToStringConverter x:Key="OptionParamsToStringConverter" />
    </UserControl.Resources>

    <WrapPanel Orientation="Horizontal">

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">

            <ScrollViewer.Styles>
                <Style Selector="RadioButton">
                    <Setter Property="Margin" Value="0,0,30,0" />
                </Style>
            </ScrollViewer.Styles>

            <Grid RowDefinitions="auto,auto,auto">

                <!--<StackPanel Grid.Row="0"  Margin="5" Orientation="Horizontal" IsVisible="{Binding IsDeveloperMode}">-->
                <StackPanel Grid.Row="0"
                            Margin="5"
                            IsVisible="False"
                            Orientation="Horizontal">

                    <CheckBox Margin="5"
                              VerticalAlignment="Center"
                              Content="Use local API"
                              IsChecked="{Binding LocalApiCheckbox}"
                              IsVisible="False" />

                    <TextBox Width="300"
                             MinWidth="200"
                             Margin="5"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             IsVisible="False"
                             PasswordChar="*"
                             PlaceholderText="API Password"
                             Text="{Binding ApiPasswordTextBox}" />

                    <TextBlock Margin="5"
                               VerticalAlignment="Center"
                               Text="{Binding UploadingStatusMessage}" />

                </StackPanel>

                <StackPanel Grid.Row="1"
                            Width="900"
                            Margin="5"
                            HorizontalAlignment="Left"
                            Grid.IsSharedSizeScope="True"
                            Orientation="Vertical">

                    <!--  Path  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="5"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Text="Path to addon folder:" />

                        <TextBox Grid.Column="1"
                                 Margin="5,0"
                                 Text="{Binding PathToAddonFolder}" />

                        <Button Grid.Column="2" Command="{Binding SelectAddonFolderCommand}">...</Button>

                    </Grid>

                    <!--  Type  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="5"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Text="Type:"
                                   ToolTip.Tip="Type of the addon." />

                        <WrapPanel Grid.Column="1"
                                   Margin="5"
                                   Orientation="Horizontal">

                            <RadioButton Content="TC"
                                         GroupName="AddonType"
                                         IsChecked="{Binding IsTcSelected}"
                                         ToolTip.Tip="Total conversion. Replaces main game files." />

                            <RadioButton Content="Map"
                                         GroupName="AddonType"
                                         IsChecked="{Binding IsMapSelected}"
                                         ToolTip.Tip="Single map." />

                            <RadioButton Content="Mod"
                                         GroupName="AddonType"
                                         IsChecked="{Binding IsModSelected}"
                                         ToolTip.Tip="Mod that doesn't replace main game files. Multiple mods can be loaded at the same time." />

                        </WrapPanel>

                    </Grid>

                    <StackPanel IsVisible="{Binding IsStep2Visible}" Orientation="Vertical">

                        <!--  Game  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Game:" />

                            <UniformGrid Grid.Column="1"
                                         Margin="5"
                                         Columns="4">

                                <RadioButton Content="Duke 3D"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Duke3D}" />

                                <RadioButton Content="Blood"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Blood}" />

                                <RadioButton Content="Shadow Warrior"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Wang}" />

                                <RadioButton Content="Ion Fury"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Fury}" />

                                <RadioButton Content="Redneck Rampage"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Redneck}" />

                                <RadioButton Content="Rised Again"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=RidesAgain}" />

                                <RadioButton Content="Powerslave"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Slave}" />

                                <RadioButton Content="NAM"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=NAM}" />

                                <RadioButton Content="WWII GI"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=WW2GI}" />

                                <RadioButton Content="Witchaven"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Witchaven}" />

                                <RadioButton Content="Witchaven II"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Witchaven2}" />

                                <RadioButton Content="Standalone"
                                             GroupName="GameSelect"
                                             IsChecked="{Binding SelectedGame, Mode=TwoWay, Converter={StaticResource GameStringToEnumConverter}, ConverterParameter=Standalone}" />

                            </UniformGrid>

                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsStep3Visible}" Orientation="Vertical">

                        <!--  Duke version  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Duke version:"
                                       ToolTip.Tip="Specific verion of Duke 3D." />

                            <WrapPanel Grid.Column="1"
                                       Margin="5"
                                       Orientation="Horizontal">

                                <RadioButton GroupName="DukeSelect" IsChecked="True">Any</RadioButton>
                                <RadioButton GroupName="DukeSelect" IsChecked="{Binding IsDukeAtomicSelected}">Atomic</RadioButton>
                                <RadioButton GroupName="DukeSelect" IsChecked="{Binding IsDuke13DSelected}">1.3D</RadioButton>
                                <RadioButton GroupName="DukeSelect" IsChecked="{Binding IsDukeWTSelected}">World Tour</RadioButton>

                            </WrapPanel>

                        </Grid>

                        <!--  Title  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Title:"
                                       ToolTip.Tip="(required) The name of the addon as displayed in the menu, and used as visual information for the user." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding AddonTitle}" />

                        </Grid>

                        <!--  Id  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="auto" MinWidth="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Id:"
                                       ToolTip.Tip="(required) Unique identifier of the addon. Can be refered to through the dependencies and incompatibles tokens." />

                            <TextBlock Grid.Column="1"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding AddonIdPrefix}" />
                            <TextBox Grid.Column="2"
                                     Margin="5"
                                     Text="{Binding AddonId}" />

                        </Grid>

                        <!--  Version  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Version:"
                                       ToolTip.Tip="(required) The version of the addon. Used by dependencies to refer to a specific required version of an addon and by launcher to inform about addon updates. Examples: 1.0, 1.1, 3.14-RC2" />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding AddonVersion}" />

                        </Grid>

                        <!--  Release date  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Release date:"
                                       ToolTip.Tip="Original release date of the addon." />

                            <DatePicker Grid.Column="1"
                                        Margin="5"
                                        SelectedDate="{Binding ReleaseDate}" />

                        </Grid>

                        <!--  Author  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Author:"
                                       ToolTip.Tip="(optional) Name of the author and/or possible contributors." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding AddonAuthor}" />

                        </Grid>

                        <!--  Main DEF  -->
                        <Grid IsVisible="{Binding !IsModSelected}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Main DEF:"
                                       ToolTip.Tip="(optional) DEF file that's loaded instead of duke3d.def/blood.def etc." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding MainDef}" />

                        </Grid>

                        <!--  Add DEF  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Additional DEFs:"
                                       ToolTip.Tip="(optional) Comma separated list of additional DEF files to be loaded together." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     PlaceholderText="Comma separated list"
                                     Text="{Binding AdditionalDefs}" />

                        </Grid>

                        <!--  Main CON  -->
                        <Grid IsVisible="{Binding IsMainConAvailable}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Main CON:"
                                       ToolTip.Tip="(optional) CON script that replaces main GAME.CON." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding MainCon}" />

                        </Grid>

                        <!--  Add CON  -->
                        <Grid IsVisible="{Binding AreDukePropertiesAvailable}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Additional CONs:"
                                       ToolTip.Tip="(optional) Comma separated list of additional CON scripts to be loaded together." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     PlaceholderText="Comma separated list"
                                     Text="{Binding AdditionalCons}" />

                        </Grid>

                        <!--  RTS  -->
                        <Grid IsVisible="{Binding IsMainConAvailable}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="RTS:"
                                       ToolTip.Tip="(optional) RTS file contains the sounds used for the Remote Ridicule taunts." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding Rts}" />

                        </Grid>

                        <!--  INI  -->
                        <Grid IsVisible="{Binding AreBloodPropertiesAvailable}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="INI:"
                                       ToolTip.Tip="(optional) Specifies .INI file that will be loaded instead of the default BLOOD.INI." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding Ini}" />

                        </Grid>

                        <!--  Main RFF  -->
                        <Grid IsVisible="{Binding AreBloodPropertiesAvailable}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Main RFF:"
                                       ToolTip.Tip="(optional) Specifies .RFF file that will be loaded instead of the default BLOOD.RFF." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding MainRff}" />

                        </Grid>

                        <!--  Sound RFF  -->
                        <Grid IsVisible="{Binding AreBloodPropertiesAvailable}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Sound RFF:"
                                       ToolTip.Tip="(optional) Specifies .RFF file that will be loaded instead of the default SOUNDS.RFF." />

                            <TextBox Grid.Column="1"
                                     Margin="5"
                                     Text="{Binding SoundRff}" />

                        </Grid>

                        <!--  Map  -->
                        <Grid IsVisible="{Binding IsMapSelected}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Start map:"
                                       ToolTip.Tip="(required) Map to be started when the game loads." />

                            <RadioButton Grid.Column="1"
                                         Margin="5,0,10,0"
                                         GroupName="MapType"
                                         IsChecked="{Binding IsFileMapTypeSelected}">
                                File
                            </RadioButton>

                            <TextBox Grid.Column="2"
                                     MinWidth="100"
                                     Margin="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     IsVisible="{Binding IsFileMapTypeSelected}"
                                     Text="{Binding MapFileName}" />
                            <RadioButton Grid.Column="3"
                                         Margin="20,0,15,0"
                                         GroupName="MapType"
                                         IsChecked="{Binding IsElMapTypeSelected}">
                                E#L#
                            </RadioButton>

                            <TextBlock Grid.Column="4"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       IsVisible="{Binding IsElMapTypeSelected}">
                                Episode
                            </TextBlock>
                            <TextBox Grid.Column="5"
                                     MinWidth="50"
                                     Margin="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     IsVisible="{Binding IsElMapTypeSelected}"
                                     Text="{Binding MapEpisode}" />
                            <TextBlock Grid.Column="6"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       IsVisible="{Binding IsElMapTypeSelected}">
                                Level
                            </TextBlock>
                            <TextBox Grid.Column="7"
                                     MinWidth="50"
                                     Margin="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     IsVisible="{Binding IsElMapTypeSelected}"
                                     Text="{Binding MapLevel}" />

                        </Grid>

                        <!--  Features  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Features:"
                                       ToolTip.Tip="(optional) List of features that the port needs to support in order to run the addon." />

                            <UniformGrid Grid.Column="1"
                                         Margin="5"
                                         Columns="3">

                                <CheckBox IsChecked="{Binding IsEdukeConsSelected}" IsVisible="{Binding AreDukePropertiesAvailable}">
                                    EDuke32 CONs
                                </CheckBox>
                                <CheckBox IsChecked="{Binding IsModernTypesSelected}" IsVisible="{Binding AreBloodPropertiesAvailable}">
                                    Modern Types
                                </CheckBox>
                                <CheckBox IsChecked="{Binding IsModelsSelected}">3D Models</CheckBox>
                                <CheckBox IsChecked="{Binding IsHightileSelected}">Hightile</CheckBox>
                                <CheckBox IsChecked="{Binding IsSlopedSelected}">Sloped Sprites</CheckBox>
                                <CheckBox IsChecked="{Binding IsTrorSelected}">TROR</CheckBox>
                                <CheckBox IsChecked="{Binding IsCstatSelected}">Wall Rotate Cstat</CheckBox>
                                <CheckBox IsChecked="{Binding IsLightingSelected}">Dynamic Lighting</CheckBox>
                                <CheckBox IsChecked="{Binding IsSndInfoSelected}" IsVisible="{Binding AreBloodPropertiesAvailable}">
                                    SndInfo
                                </CheckBox>
                                <CheckBox IsChecked="{Binding IsTilefromtextureSelected}">Tilefromtexture</CheckBox>

                            </UniformGrid>

                        </Grid>

                        <!--  Dependencies  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Dependencies:"
                                       ToolTip.Tip="(optional) List of ids and versions of the addons that are required for this addon to work." />

                            <ListBox Grid.Column="1"
                                     Margin="3"
                                     ItemsSource="{Binding DependenciesList}">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center">Id:</TextBlock>

                                            <TextBox Name="AddonId"
                                                     Grid.Column="1"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding Id}"
                                                     TextAlignment="Left"
                                                     TextWrapping="NoWrap" />

                                            <TextBlock Grid.Column="2" VerticalAlignment="Center">Version:</TextBlock>

                                            <TextBox Grid.Column="3"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding Version}"
                                                     TextAlignment="Left"
                                                     TextWrapping="NoWrap" />

                                            <Button Grid.Column="4"
                                                    Width="{Binding Bounds.Height, ElementName=AddonId}"
                                                    Height="{Binding Bounds.Height, ElementName=AddonId}"
                                                    Margin="3"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=((vm:DevViewModel)DataContext).RemoveDependencyCommand}"
                                                    CommandParameter="{Binding}">
                                                x
                                            </Button>

                                        </Grid>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>


                            </ListBox>

                            <Button Grid.Column="2"
                                    Width="{Binding $self.Bounds.Height}"
                                    Margin="3"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding AddDependencyCommand}">
                                +
                            </Button>

                        </Grid>

                        <!--  Incompatibilities  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Incompatibilities:"
                                       ToolTip.Tip="(optional) List of ids and versions of the addons that are incompatible with this addon." />

                            <ListBox Grid.Column="1"
                                     Margin="3"
                                     ItemsSource="{Binding IncompatibilitiesList}">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center">Id:</TextBlock>

                                            <TextBox Name="AddonId"
                                                     Grid.Column="1"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding Id}"
                                                     TextAlignment="Left"
                                                     TextWrapping="NoWrap" />

                                            <TextBlock Grid.Column="2" VerticalAlignment="Center">Version:</TextBlock>

                                            <TextBox Grid.Column="3"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding Version}"
                                                     TextAlignment="Left"
                                                     TextWrapping="NoWrap" />

                                            <Button Grid.Column="4"
                                                    Width="{Binding Bounds.Height, ElementName=AddonId}"
                                                    Height="{Binding Bounds.Height, ElementName=AddonId}"
                                                    Margin="3"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=((vm:DevViewModel)DataContext).RemoveIncompatibilityCommand}"
                                                    CommandParameter="{Binding}">
                                                x
                                            </Button>

                                        </Grid>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>


                            </ListBox>

                            <Button Grid.Column="2"
                                    Width="{Binding $self.Bounds.Height}"
                                    Margin="3"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding AddIncompatibilityCommand}">
                                +
                            </Button>

                        </Grid>

                        <!--  Options  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       Text="Options:"
                                       ToolTip.Tip="(optional) //TODO" />

                            <ListBox x:Name="Options"
                                     Grid.Column="1"
                                     Margin="3"
                                     ItemsSource="{Binding OptionsList}">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center">Name:</TextBlock>

                                            <TextBox Name="AddonId"
                                                     Grid.Column="1"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding OptionName}"
                                                     TextAlignment="Left"
                                                     TextWrapping="NoWrap" />

                                            <TextBlock Grid.Column="2" VerticalAlignment="Center">Params:</TextBlock>

                                            <TextBox Grid.Column="3"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding Parameters, Converter={StaticResource OptionParamsToStringConverter}}"
                                                     TextAlignment="Left"
                                                     TextWrapping="NoWrap" />

                                            <Button Grid.Column="4"
                                                    Width="{Binding Bounds.Height, ElementName=AddonId}"
                                                    Height="{Binding Bounds.Height, ElementName=AddonId}"
                                                    Margin="3"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=((vm:DevViewModel)DataContext).RemoveOptionCommand}"
                                                    CommandParameter="{Binding}">
                                                x
                                            </Button>

                                        </Grid>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>


                            </ListBox>

                            <Button Grid.Column="2"
                                    Width="{Binding $self.Bounds.Height}"
                                    Margin="3"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding AddOptionCommand}">
                                +
                            </Button>

                        </Grid>

                        <!--  Executables  -->

                        <Expander Margin="5"
                                  HorizontalAlignment="Stretch"
                                  Header="Executables"
                                  ToolTip.Tip="List of built-in executables that will be used instead of the ones downloaded from the launcher.">

                            <Grid ColumnDefinitions="auto,*,*" RowDefinitions="auto,auto,auto,auto,auto,auto,auto">

                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Text="Windows" />


                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Text="Linux" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="NBlood:" />

                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding WindowsNBloodExe}" />

                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding LinuxNBloodExe}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="NotBlood:" />

                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding WindowsNotBloodExe}" />

                                <TextBox Grid.Row="2"
                                         Grid.Column="2"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding LinuxNotBloodExe}" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="EDuke32:" />

                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding WindowsEDukeExe}" />

                                <TextBox Grid.Row="3"
                                         Grid.Column="2"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding LinuxEDukeExe}" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="RedNukem:" />

                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding WindowsRedNukemExe}" />

                                <TextBox Grid.Row="4"
                                         Grid.Column="2"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding LinuxRedNukemExe}" />

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="Raze:" />

                                <TextBox Grid.Row="5"
                                         Grid.Column="1"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding WindowsRazeExe}" />

                                <TextBox Grid.Row="5"
                                         Grid.Column="2"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding LinuxRazeExe}" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Margin="5"
                                           VerticalAlignment="Center"
                                           Text="PCExhumed:" />

                                <TextBox Grid.Row="6"
                                         Grid.Column="1"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding WindowsPCExhumedExe}" />

                                <TextBox Grid.Row="6"
                                         Grid.Column="2"
                                         MinWidth="150"
                                         Margin="5"
                                         Text="{Binding LinuxPCExhumedExe}" />

                            </Grid>
                        </Expander>

                        <!--  Description  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" SharedSizeGroup="MySizeGroup" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Margin="5"
                                       VerticalAlignment="Top">
                                Description:
                            </TextBlock>

                            <TextBox Grid.Column="1"
                                     MinHeight="100"
                                     Margin="5"
                                     AcceptsReturn="True"
                                     Text="{Binding AddonDescription}"
                                     TextWrapping="Wrap" />

                        </Grid>

                        <!--  Buttons  -->
                        <StackPanel Orientation="Horizontal">

                            <Button MinWidth="150"
                                    Margin="5"
                                    Padding="10"
                                    HorizontalContentAlignment="Center"
                                    Background="{DynamicResource SystemAccentColor}"
                                    Command="{Binding PreviewJsonCommand}"
                                    IsEnabled="{Binding !IsInProgress}"
                                    ToolTip.Tip="Preivew resulting addon.json file.">
                                Preview JSON
                            </Button>

                            <Button MinWidth="150"
                                    Margin="5"
                                    Padding="10"
                                    HorizontalContentAlignment="Center"
                                    Background="{DynamicResource SystemAccentColor}"
                                    Command="{Binding SaveJsonCommand}"
                                    IsEnabled="{Binding !IsInProgress}"
                                    ToolTip.Tip="Save addon.json and rename addon folder to match addon id.">
                                Save changes
                            </Button>

                            <Button MinWidth="150"
                                    Margin="5"
                                    Padding="10"
                                    HorizontalContentAlignment="Center"
                                    Background="{DynamicResource SystemAccentColor}"
                                    Command="{Binding CreateZipCommand}"
                                    IsEnabled="{Binding !IsInProgress}"
                                    ToolTip.Tip="Create zip and put it into a suitable game folder">
                                Create ZIP
                            </Button>

                            <Button MinWidth="150"
                                    Margin="5"
                                    Padding="10"
                                    HorizontalContentAlignment="Center"
                                    Background="{DynamicResource SystemAccentColor}"
                                    Command="{Binding SubmitAddonCommand}"
                                    IsEnabled="{Binding !IsInProgress}"
                                    ToolTip.Tip="Upload addon to the developer.">
                                Upload addon
                            </Button>

                        </StackPanel>

                    </StackPanel>

                    <StackPanel Orientation="Horizontal">

                        <Button MinWidth="150"
                                Margin="5"
                                Padding="10"
                                Command="{Binding AddAddonCommand}"
                                Content="Add addons to the database..."
                                IsVisible="{Binding IsDeveloperMode}" />

                        <Button MinWidth="150"
                                Margin="5"
                                Padding="10"
                                Command="{Binding UpdateManifestsCommand}"
                                Content="Update manifests.json..."
                                IsVisible="{Binding IsDeveloperMode}" />

                    </StackPanel>

                    <ProgressBar Height="20"
                                 Margin="5"
                                 IsVisible="{Binding IsInProgress}"
                                 Value="{Binding ProgressBarValue}" />

                    <md:MarkdownScrollViewer Margin="5,0" Markdown="Check [JSON specifications](https://github.com/fgsfds/BuildLauncher/wiki/addon.json-Specifications) for additional information." />

                    <TextBlock MaxWidth="900"
                               Margin="10"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{Binding ErrorTextColor}"
                               Text="{Binding ErrorText}"
                               TextWrapping="Wrap" />

                </StackPanel>

            </Grid>

        </ScrollViewer>

        <ScrollViewer>

            <TextBlock MaxWidth="500"
                       Margin="5"
                       HorizontalAlignment="Left"
                       Text="{Binding JsonText}"
                       TextWrapping="Wrap" />

        </ScrollViewer>

    </WrapPanel>
</UserControl>
