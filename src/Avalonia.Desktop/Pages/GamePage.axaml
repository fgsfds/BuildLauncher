<UserControl x:Class="Avalonia.Desktop.Pages.GamePage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="clr-namespace:Avalonia.Desktop.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:GamePageViewModel">

    <Grid RowDefinitions="*">

        <TabControl>
            <TabItem Margin="5">

                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock>Campaigns</TextBlock>

                        <i:Icon Margin="5,0,0,0"
                                BorderBrush="Black"
                                Foreground="Crimson"
                                IsVisible="{Binding IsCampaignsAlarmShown}"
                                Value="fa7-circle-exclamation" />
                    </StackPanel>
                </TabItem.Header>

                <UserControl Content="{Binding Campaigns}" />
            </TabItem>

            <TabItem Margin="5" IsVisible="{Binding Maps, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}">

                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock>Maps</TextBlock>

                        <i:Icon Margin="5,0,0,0"
                                Foreground="Crimson"
                                IsVisible="{Binding IsMapsAlarmShown}"
                                Value="fa7-circle-exclamation" />
                    </StackPanel>
                </TabItem.Header>

                <UserControl Content="{Binding Maps}" />
            </TabItem>

            <TabItem Margin="5" IsVisible="{Binding Mods, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}">

                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock>Mods</TextBlock>

                        <i:Icon Margin="5,0,0,0"
                                Foreground="Crimson"
                                IsVisible="{Binding IsModsAlarmShown}"
                                Value="fa7-circle-exclamation" />
                    </StackPanel>
                </TabItem.Header>

                <UserControl Content="{Binding Mods}" />
            </TabItem>

            <TabItem Margin="5">

                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Downloads" />
                        <i:Icon Margin="5,0,0,0"
                                Foreground="Crimson"
                                IsVisible="{Binding IsDownloadsAlarmShown}"
                                ToolTip.Tip="Updates available"
                                Value="fa7-circle-exclamation" />
                    </StackPanel>
                </TabItem.Header>

                <UserControl x:Name="DownControl" Content="{Binding Downloads}" />
            </TabItem>

        </TabControl>

    </Grid>

</UserControl>
